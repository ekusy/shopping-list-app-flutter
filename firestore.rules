rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // plan / planExpiresAt フィールドの書き込み保護（#39 マネタイズ M0）。
    //
    // この2フィールドはサーバー側（RevenueCat Webhook / Functions の Admin SDK）
    // のみが書き込む正本であり、クライアントからの新規設定・変更を禁止する。
    // Admin SDK は Rules をバイパスするため、Functions からの書き込みには影響しない。
    //
    // - create（resource == null）: 両フィールドが未設定（null）であることを要求。
    // - update: 既存値からの変更がないことを要求。
    function planFieldsUnchanged() {
      let existingPlan = resource == null ? null : resource.data.get('plan', null);
      let existingExp  = resource == null ? null : resource.data.get('planExpiresAt', null);
      return request.resource.data.get('plan', null) == existingPlan
          && request.resource.data.get('planExpiresAt', null) == existingExp;
    }

    // ユーザードキュメント:
    //  - 書き込み: 本人のみ（plan / planExpiresAt は変更不可。#39）
    //  - 読み取り: 本人、または対象ユーザーと同一グループに属するメンバー
    //    （メンバーの表示名・アバターを互いに表示するために必要。#22）
    match /users/{uid} {
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && planFieldsUnchanged();

      allow read: if request.auth != null
                  && (
                    request.auth.uid == uid
                    ||
                    (resource.data.groupId != null
                     && request.auth.uid in
                        get(/databases/$(database)/documents/groups/$(resource.data.groupId))
                        .data.memberIds)
                  );
    }

    match /groups/{groupId} {
      // メンバーのみ読み取り可
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.memberIds;

      // 新規作成: 自分が ownerId かつ memberIds に含まれる場合
      // 更新: 現在のメンバーによる変更のみ許可
      // plan / planExpiresAt は変更不可（#39）
      allow write: if request.auth != null
                   && (
                     (request.resource.data.ownerId == request.auth.uid
                      && request.resource.data.memberIds.hasAll([request.auth.uid]))
                     ||
                     request.auth.uid in resource.data.memberIds
                   )
                   && planFieldsUnchanged();

      // アイテム（フラットパス #142〜）: グループメンバーのみ読み書き可
      match /items/{itemId} {
        allow read, write: if request.auth != null
                           && request.auth.uid in
                              get(/databases/$(database)/documents/groups/$(groupId))
                              .data.memberIds;
      }

      // タグ: グループメンバーのみ読み書き可
      match /tags/{tagId} {
        allow read, write: if request.auth != null
                           && request.auth.uid in
                              get(/databases/$(database)/documents/groups/$(groupId))
                              .data.memberIds;
      }

      // 購買履歴（生イベント）: Functions（Admin SDK）のみが書き込む。
      // 読み取りはグループメンバーのみ（#37 Phase 0 PR2）。
      match /itemHistory/{eventId} {
        allow read: if request.auth != null
                    && request.auth.uid in
                       get(/databases/$(database)/documents/groups/$(groupId))
                       .data.memberIds;
        allow write: if false;
      }

      // 購買履歴サマリー（商品別）: Functions（Admin SDK）のみが書き込む。
      // 読み取りはグループメンバーのみ（#37 Phase 0 PR2）。
      match /purchaseHistorySummaries/{nameKey} {
        allow read: if request.auth != null
                    && request.auth.uid in
                       get(/databases/$(database)/documents/groups/$(groupId))
                       .data.memberIds;
        allow write: if false;
      }

      // リスト（#142 で廃止。既存データ互換のためルールは残置）:
      // グループメンバーのみ読み書き可
      match /lists/{listId} {
        allow read, write: if request.auth != null
                           && request.auth.uid in
                              get(/databases/$(database)/documents/groups/$(groupId))
                              .data.memberIds;

        match /items/{itemId} {
          allow read, write: if request.auth != null
                             && request.auth.uid in
                                get(/databases/$(database)/documents/groups/$(groupId))
                                .data.memberIds;
        }
      }
    }
  }
}
